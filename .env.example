# ───────────────────────────────────────────────────────────────────────────
# Casino – Environment configuration
#
# Copy this file as ".env" (or rename it) and fill in your values.
# This file is loaded automatically by auth/database.py via python-dotenv.
# NEVER commit a .env with real credentials to Git.
# ───────────────────────────────────────────────────────────────────────────

# ── PostgreSQL connection URL ────────────────────────────────────────────────
# Format: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DATABASE
# Default points to a local PostgreSQL instance:
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/casino_db
