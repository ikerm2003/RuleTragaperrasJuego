# ─────────────────────────────────────────────────────────────────────────────
# Copia este archivo como ".env" en la carpeta Server/ y rellena los valores.
# NUNCA subas el .env real a Git (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos PostgreSQL ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://casino:CAMBIA_ESTA_CONTRASEÑA@postgres:5432/casino

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ──────────────────────────────────────────────────────────────────────
# Genera un valor aleatorio seguro con:
#   python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=CAMBIA_ESTO_POR_UNA_CADENA_ALEATORIA_SEGURA_DE_AL_MENOS_64_CHARS
JWT_EXPIRE_HOURS=24

# ── Servidor ─────────────────────────────────────────────────────────────────
# Dominio público del servidor (usado por Nginx y Certbot para SSL)
DOMAIN=tu-dominio.com

# ── Logging ──────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── PostgreSQL (para el servicio postgres de docker-compose) ─────────────────
POSTGRES_USER=casino
POSTGRES_PASSWORD=CAMBIA_ESTA_CONTRASEÑA
POSTGRES_DB=casino
